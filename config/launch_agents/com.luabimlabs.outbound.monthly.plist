    <dict>
        <key>Day</key>
        <integer>1</integer>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/choejeong-yeon/LUA BIM LABS/scripts/outbound_sales/data/logs/launchd.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/choejeong-yeon/LUA BIM LABS/scripts/outbound_sales/data/logs/launchd_err.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>

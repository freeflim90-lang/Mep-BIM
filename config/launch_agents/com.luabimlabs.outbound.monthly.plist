<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.luabimlabs.outbound.monthly</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/choejeong-yeon/LUA BIM LABS/scripts/outbound_sales/run_monthly.sh</string>
    </array>

    <!-- 매월 1일 오전 9시 실행 -->

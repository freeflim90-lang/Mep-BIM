<Window x:Class="RevitLUAChat.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LUA BIM LABS Revit Assistant"
        Height="600"
        Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">
            <Ellipse Width="12"
                     Height="12"
                     Fill="#50FA7B"
                     Margin="0,0,8,0"
                     VerticalAlignment="Center"/>
            <TextBlock Text="LUA BIM LABS"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="#CDD6F4"
                       VerticalAlignment="Center"/>
            <TextBlock Text=" | Revit Assistant"
                       FontSize="11"
                       Foreground="#6C7086"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      x:Name="ChatScroll"
                      Background="#181825"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ChatPanel"
                        Margin="8"/>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="#313244"
                CornerRadius="4"
                Margin="0,6,0,0"
                Padding="8,4">
            <TextBlock x:Name="ContextLabel"
                       Text="선택된 Revit 요소가 없습니다."
                       FontSize="11"
                       Foreground="#6C7086"
                       TextWrapping="Wrap"/>
        </Border>

        <Grid Grid.Row="3"
              Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <TextBox x:Name="InputBox"
                         Background="#313244"
                         Foreground="#CDD6F4"
                         BorderBrush="#45475A"
                         BorderThickness="1"
                         Padding="10,8"
                         FontSize="13"
                         TextWrapping="Wrap"
                         AcceptsReturn="False"
                         VerticalContentAlignment="Center"
                         KeyDown="InputBox_KeyDown"
                         GotFocus="InputBox_GotFocus"
                         LostFocus="InputBox_LostFocus"/>
                <TextBlock x:Name="PlaceholderText"
                           Text="Revit, Dynamo, 설비 BIM 질문을 입력해 주세요."
                           Foreground="#6C7086"
                           FontSize="13"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           Padding="0,8"/>
            </Grid>

            <Button x:Name="SendBtn"
                    Grid.Column="1"
                    Content="전송"
                    Width="60"
                    Margin="6,0,0,0"
                    Background="#89B4FA"
                    Foreground="#1E1E2E"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="SendBtn_Click"
                    Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
